{
  "name": "wukong-codex-forge",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "vite --host 127.0.0.1",
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/native-theme.mjs validate --definition themes/native-wukong.json",
    "check": "npm run validate && npm test",
    "test:e2e": "node tests/run-studio-e2e.mjs",
    "test:theme": "node --test tests/native-theme.test.mjs",
    "test:lifecycle": "node --test tests/lifecycle-contract.test.mjs tests/restore-path.test.mjs",
    "test:native": "node --test tests/native-theme.test.mjs tests/lifecycle-contract.test.mjs tests/restore-path.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "pngjs": "^7.0.0",
    "vite": "^7.1.7"
  }
}
