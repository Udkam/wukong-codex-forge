{
  "name": "wukong-codex-forge",
  "version": "0.12.3",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "vite --host 127.0.0.1",
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/native-theme.mjs validate --definition themes/native-wukong.json",
    "check": "npm run validate && npm test",
    "test:e2e": "node tests/run-studio-e2e.mjs",
    "test:theme": "node --test tests/native-theme.test.mjs",
    "test:lifecycle": "node --test tests/lifecycle-contract.test.mjs tests/restore-path.test.mjs tests/preserving-install-contract.test.mjs",
    "test:native": "node --test tests/native-theme.test.mjs tests/lifecycle-contract.test.mjs tests/restore-path.test.mjs",
    "test:runtime-states": "node --test tests/background-runtime-v13.test.mjs tests/scene-palette.test.mjs",
    "test:runtime-visual": "node --test tests/background-runtime-v13.test.mjs",
    "test:managed-package": "node --test tests/managed-package.test.mjs",
    "test:native-pets": "node --test tests/native-pets-contract.test.mjs",
    "prepare:native-pets": "node scripts/prepare-native-pets.mjs",
    "test:preserve": "node --test tests/preserving-install-contract.test.mjs",
    "test:scene-palette": "node --test tests/scene-palette.test.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "pngjs": "^7.0.0",
    "vite": "^7.1.7"
  }
}
